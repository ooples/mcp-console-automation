{
  "name": "console-automation-mcp",
  "version": "1.1.3",
  "description": "MCP server for AI-driven console application automation and monitoring",
  "mcpName": "io.github.ooples/console-automation-mcp",
  "main": "dist/mcp/server.js",
  "type": "module",
  "bin": {
    "console-automation-mcp": "./dist/mcp/server.js",
    "mcp-console": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/mcp/server.ts",
    "start": "node dist/mcp/server.js",
    "start:persistent": "node dist/mcp/server.js",
    "test": "jest src/tests tests/protocols tests/ErrorDetector.test.ts --runInBand",
    "test:unit": "jest src/tests tests/protocols tests/ErrorDetector.test.ts --runInBand",
    "test:integration": "jest test/integration --runInBand",
    "test:protocols": "jest tests/integration/protocols --runInBand",
    "test:stress": "jest test/stress --runInBand",
    "test:stress:smoke": "node scripts/stress-smoke-test.mjs",
    "test:all": "jest --runInBand",
    "test:ssh": "jest test/integration/ssh.test.ts",
    "test:ssh:smoke": "node scripts/ssh-smoke-test.mjs",
    "test:sessions": "jest test/integration/session-management.test.ts",
    "test:errors": "jest test/integration/error-detection.test.ts",
    "test:load": "jest test/stress/load.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:mcp": "node scripts/mcp-smoke-test.mjs",
    "test:logger": "node scripts/logger-smoke-test.mjs",
    "test:installer": "node scripts/installer-smoke-test.mjs",
    "test:package": "node scripts/package-smoke-test.mjs",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "console",
    "automation",
    "terminal",
    "pty",
    "ai",
    "llm"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "author": "ooples",
  "license": "MIT",
